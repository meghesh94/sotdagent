# All optional — core discovery works without any of these

# Spotify API — https://developer.spotify.com/dashboard
# Enables: popularity filter, publish to Spotify playlist
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback
SPOTIFY_PLAYLIST_ID=

# YT Music — browser auth (run: ytmusicapi oauth)
# Enables: publishing to YT Music playlist
YTMUSIC_AUTH_FILE=oauth.json
YTMUSIC_PLAYLIST_ID=
