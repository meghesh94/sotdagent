# Spotify API — https://developer.spotify.com/dashboard
# Required for: popularity filter, publish to Spotify playlist
SPOTIFY_CLIENT_ID=your_client_id
SPOTIFY_CLIENT_SECRET=your_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback
SPOTIFY_PLAYLIST_ID=your_publish_playlist_id

# Google Sheets — service account JSON key path
# Required for: inventory (approve/publish tracking)
GOOGLE_SHEETS_CREDS_FILE=credentials.json
GOOGLE_SHEET_NAME=Song Inventory

# Telegram Bot — https://t.me/BotFather
# Required for: publishing song notifications
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# YT Music — browser auth (run: ytmusicapi oauth)
# Required for: publishing to YT Music playlist
YTMUSIC_AUTH_FILE=oauth.json
YTMUSIC_PLAYLIST_ID=your_playlist_id
YTMUSIC_OAUTH_CLIENT_ID=
YTMUSIC_OAUTH_CLIENT_SECRET=

# Gemini (optional — deprecated, MERT is used instead)
GEMINI_API_KEY=

# Song library CSV (optional — web UI uses playlists instead)
SONG_LIBRARY_CSV=
